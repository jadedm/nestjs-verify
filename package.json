{
  "name": "nestjs-verify-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Self-hosted Twilio Verify-style OTP for NestJS. Bring your own SMS provider.",
  "repository": {
    "type": "git",
    "url": "https://github.com/jadedm/nestjs-verify.git"
  },
  "author": "jadedm <jadedmanish@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "pnpm -r run test",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "test:adapters": "docker compose -f scripts/docker-compose.smoke.yml up -d --wait && pnpm build && node scripts/smoke-adapters.mjs; ec=$?; docker compose -f scripts/docker-compose.smoke.yml down -v; exit $ec"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@jadedm/nestjs-verify-mongo": "workspace:*",
    "@jadedm/nestjs-verify-postgres": "workspace:*",
    "@jadedm/nestjs-verify-redis": "workspace:*",
    "@swc/core": "^1.15.41",
    "@types/node": "^20.11.0",
    "ioredis": "^5.4.0",
    "mongodb": "^6.5.0",
    "pg": "^8.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.5"
    }
  }
}
