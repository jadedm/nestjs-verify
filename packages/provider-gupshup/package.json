{
  "name": "@jadedm/nestjs-verify-gupshup",
  "version": "0.4.0",
  "description": "Gupshup SMS provider adapter for @jadedm/nestjs-verify. India and SEA SMS dispatch.",
  "keywords": ["nestjs", "otp", "verify", "gupshup", "sms", "india"],
  "license": "MIT",
  "author": "jadedm <jadedmanish@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jadedm/nestjs-verify.git",
    "directory": "packages/provider-gupshup"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.mts", "default": "./dist/index.mjs" },
      "require": { "types": "./dist/index.d.ts", "default": "./dist/index.js" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jadedm/nestjs-verify": "workspace:^"
  },
  "devDependencies": {
    "@jadedm/nestjs-verify": "workspace:*"
  }
}
