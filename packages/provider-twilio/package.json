{
  "name": "@jadedm/nestjs-verify-twilio",
  "version": "0.1.0",
  "description": "Twilio SMS provider adapter for @jadedm/nestjs-verify.",
  "keywords": ["nestjs", "otp", "verify", "twilio", "sms"],
  "license": "MIT",
  "author": "jadedm <jadedmanish@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jadedm/nestjs-verify.git",
    "directory": "packages/provider-twilio"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jadedm/nestjs-verify": "workspace:^",
    "twilio": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@jadedm/nestjs-verify": "workspace:*",
    "twilio": "^5.0.0"
  }
}
