{
  "name": "@jadedm/nestjs-verify-mongo",
  "version": "0.5.0",
  "description": "MongoDB store adapter for @jadedm/nestjs-verify (verifications + abuse log).",
  "keywords": [
    "nestjs",
    "otp",
    "verify",
    "mongodb",
    "mongo"
  ],
  "license": "MIT",
  "author": "jadedm <jadedmanish@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jadedm/nestjs-verify.git",
    "directory": "packages/store-mongo"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@jadedm/nestjs-verify": "workspace:^",
    "mongodb": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@jadedm/nestjs-verify": "workspace:*",
    "mongodb": "^6.5.0"
  }
}
